DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db
AI_KEYS_ENCRYPTION_SECRET=replace-with-a-long-random-32-plus-character-secret

# Optional: shown in Admin Release Center after a real repository is connected.
GITHUB_REPOSITORY_URL=https://github.com/your-org/your-repository

# Google OAuth for admin sign-in. Add the exact callback URL in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADMIN_EMAILS=admin@example.com
GOOGLE_REDIRECT_URI=https://your-domain.example/api/auth/google/callback
GOOGLE_STUDENT_REDIRECT_URI=https://your-domain.example/api/auth/student/google/callback

# Optional: providers automatically appear in AI Control Center when configured.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional Cloudflare Turnstile for public registration.
# Set both values; the public site key is safe to expose in the browser.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional SMTP for sending resume attachments from user panel.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=VibeLab <no-reply@your-domain.example>
